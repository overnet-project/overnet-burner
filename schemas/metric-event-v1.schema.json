{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overnet-project.org/schemas/overnet-burner/metric-event-v1.schema.json",
  "title": "overnet-burner metric event v1",
  "description": "One measurement record emitted by a burner worker. Streams are JSONL: one event object per line.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "metric_version",
    "run_id",
    "worker_id",
    "host",
    "role",
    "operation",
    "started_at",
    "finished_at",
    "duration_ms",
    "status"
  ],
  "properties": {
    "metric_version": {
      "const": 1
    },
    "run_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "worker_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "host": {
      "$ref": "#/$defs/non_empty_string"
    },
    "role": {
      "$ref": "#/$defs/non_empty_string"
    },
    "operation": {
      "$ref": "#/$defs/non_empty_string"
    },
    "started_at": {
      "$ref": "#/$defs/rfc3339_utc"
    },
    "finished_at": {
      "$ref": "#/$defs/rfc3339_utc"
    },
    "duration_ms": {
      "type": "number",
      "minimum": 0
    },
    "status": {
      "enum": ["success", "error"],
      "type": "string"
    },
    "error": {
      "$ref": "#/$defs/non_empty_string"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "rfc3339_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    }
  }
}
