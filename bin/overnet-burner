#!/usr/bin/env perl
use strict;
use warnings;

use FindBin;
use Getopt::Long qw(GetOptionsFromArray);
use lib "$FindBin::Bin/../lib";

use Overnet::Burner::Config;
use Overnet::Burner::Plan;
use Overnet::Burner::Provider;
use Overnet::Burner::RunLedger;

exit main(@ARGV) unless caller;

sub main {
    my @args = @_;
    my $command = shift @args || return _usage();

    my $status = eval {
        if ($command eq 'validate') {
            return _validate(@args);
        }
        if ($command eq 'plan') {
            return _plan(@args);
        }
        if ($command eq 'init-run') {
            return _init_run(@args);
        }
        if ($command eq 'run') {
            return _run(@args);
        }

        die "unknown command: $command\n";
    };

    if ($@) {
        my $error = $@ || 'command failed';
        chomp $error;
        print STDERR "$error\n";
        return 2;
    }

    return $status;
}

sub _validate {
    my @args = @_;
    my $scenario_path;

    GetOptionsFromArray(
        \@args,
        'scenario=s' => \$scenario_path,
    ) or return _usage();

    die "--scenario is required\n" unless $scenario_path;
    die "unexpected arguments: @args\n" if @args;

    my $scenario = Overnet::Burner::Config->load_file($scenario_path);
    print "valid scenario: $scenario->{run}{name}\n";

    return 0;
}

sub _plan {
    my @args = @_;
    my $scenario_path;

    GetOptionsFromArray(
        \@args,
        'scenario=s' => \$scenario_path,
    ) or return _usage();

    die "--scenario is required\n" unless $scenario_path;
    die "unexpected arguments: @args\n" if @args;

    my $scenario = Overnet::Burner::Config->load_file($scenario_path);
    print Overnet::Burner::Plan->canonical_json(
        Overnet::Burner::Plan->build($scenario),
    );

    return 0;
}

sub _init_run {
    my @args = @_;
    my $scenario_path;
    my $runs_dir = 'runs';
    my $run_id;

    GetOptionsFromArray(
        \@args,
        'scenario=s' => \$scenario_path,
        'runs-dir=s' => \$runs_dir,
        'run-id=s'   => \$run_id,
    ) or return _usage();

    die "--scenario is required\n" unless $scenario_path;
    die "unexpected arguments: @args\n" if @args;

    my $scenario = Overnet::Burner::Config->load_file($scenario_path);
    my $ledger = Overnet::Burner::RunLedger->create(
        scenario      => $scenario,
        scenario_path => $scenario_path,
        runs_dir      => $runs_dir,
        defined $run_id ? (run_id => $run_id) : (),
    );

    print "created run: $ledger->{run_dir}\n";

    return 0;
}

sub _run {
    my @args = @_;
    my $scenario_path;
    my $runs_dir = 'runs';
    my $run_id;
    my $provider_name = 'noop';

    GetOptionsFromArray(
        \@args,
        'scenario=s' => \$scenario_path,
        'runs-dir=s' => \$runs_dir,
        'run-id=s'   => \$run_id,
        'provider=s' => \$provider_name,
    ) or return _usage();

    die "--scenario is required\n" unless $scenario_path;
    die "unexpected arguments: @args\n" if @args;

    my $scenario = Overnet::Burner::Config->load_file($scenario_path);
    my $ledger = Overnet::Burner::RunLedger->create(
        scenario      => $scenario,
        scenario_path => $scenario_path,
        runs_dir      => $runs_dir,
        defined $run_id ? (run_id => $run_id) : (),
    );

    $ledger->mark_started(execution_provider => $provider_name);

    my $summary = eval {
        my $plan = Overnet::Burner::RunLedger->load_plan($ledger->{run_dir});
        my $provider = Overnet::Burner::Provider->load(
            name    => $provider_name,
            ledger  => $ledger,
            plan    => $plan,
            run_dir => $ledger->{run_dir},
        );
        $provider->run_lifecycle;
    };
    if ($@) {
        my $error = $@ || 'run failed';
        chomp $error;
        $ledger->finish(
            status             => 'failed',
            execution_provider => $provider_name,
            error              => $error,
        );
        die "$error\n";
    }

    $ledger->finish(
        status             => 'completed',
        execution_provider => $provider_name,
        lifecycle          => $summary,
    );

    print "completed run: $ledger->{run_dir}\n";

    return 0;
}

sub _usage {
    print STDERR <<'USAGE';
usage:
  overnet-burner validate --scenario scenarios/single-relay-baseline.yml
  overnet-burner plan --scenario scenarios/single-relay-baseline.yml
  overnet-burner init-run --scenario scenarios/single-relay-baseline.yml [--runs-dir runs] [--run-id ID]
  overnet-burner run --scenario scenarios/single-relay-baseline.yml [--runs-dir runs] [--run-id ID] [--provider noop]
USAGE
    return 2;
}
