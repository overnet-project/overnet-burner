#!/usr/bin/env perl
use strictures 2;

use FindBin;
use lib "$FindBin::Bin/../lib";

use Getopt::Long     qw(GetOptionsFromArray);
use IO::Select       ();
use IO::Socket::INET ();
use JSON             ();

use Overnet::Burner::Adversary::Server;

our $VERSION = '0.001';

my $JSON           = JSON->new->utf8->canonical;
my $MAX_LINE_BYTES = 8_192;

# Read timeout (seconds) and maximum request-body size (bytes). Overridable via
# the environment so tests can drive the hostile-client paths quickly.
sub _read_timeout { return $ENV{OVERNET_BURNER_ADVERSARY_READ_TIMEOUT} || 30 }
sub _max_body     { return $ENV{OVERNET_BURNER_ADVERSARY_MAX_BODY}     || 1_048_576 }

if (!caller) {
  exit run(@ARGV);
}

sub run {
  my (@argv) = @_;
  my %opt = (host => '127.0.0.1', port => 7480);
  GetOptionsFromArray(\@argv, 'host=s' => \$opt{host}, 'port=i' => \$opt{port})
    or die "usage: overnet-burner-adversary-server [--host HOST] [--port PORT]\n";

  my $server   = Overnet::Burner::Adversary::Server->new;
  my $listener = IO::Socket::INET->new(
    LocalHost => $opt{host},
    LocalPort => $opt{port},
    Proto     => 'tcp',
    Listen    => 16,
    ReuseAddr => 1,
  ) or die "listen on $opt{host}:$opt{port}: $!\n";

  print {*STDERR} "adversary server listening on $opt{host}:$opt{port}\n"
    or die "print: $!\n";

  # A hostile or vanished client must never take the loop down: a dropped
  # connection surfaces as SIGPIPE or a write failure, so ignore the signal and
  # keep each connection's handling inside its own eval.
  local $SIG{PIPE} = 'IGNORE';

  while (my $connection = $listener->accept) {
    if (!eval { _serve_connection($server, $connection); 1 }) {
      warn "adversary server: dropping connection: $@";
    }
    close $connection or warn "adversary server: close: $!\n";
  }

  return 0;
}

sub _serve_connection {
  my ($server, $connection) = @_;

  my $request = _read_request($connection);
  if (!$request) {
    return _write_response($connection, {status => 400, body => {error => 'malformed request'}});
  }
  if ($request->{too_large}) {
    return _write_response($connection, {status => 413, body => {error => 'request body too large'}});
  }

  my $body;
  if (length $request->{body}) {
    my $decoded = eval { $JSON->decode($request->{body}) };
    if (!$decoded) {
      return _write_response($connection, {status => 400, body => {error => 'request body is not valid JSON'}});
    }
    $body = $decoded;
  }

  my $response = $server->dispatch(
    method => $request->{method},
    path   => $request->{path},
    body   => $body,
  );
  return _write_response($connection, $response);
}

sub _read_request {
  my ($connection) = @_;
  my $select = IO::Select->new($connection);

  my $request_line = _read_limited_line($connection, $select);
  if (!(defined $request_line && $request_line =~ /\A(\S+)\ (\S+)\ HTTP/mxs)) {
    return;
  }
  my ($method, $target) = ($1, $2);
  $target =~ s/[?].*\z//mxs;

  my $length = 0;
  while (defined(my $header = _read_limited_line($connection, $select))) {
    $header =~ s/\r?\n\z//mxs;
    if (!length $header) {
      last;
    }
    if ($header =~ /\AContent-Length:\s*(\d+)\z/imxs) {
      $length = $1;
    }
  }

  # Reject an over-large body before allocating for it, but keep enough of the
  # request parsed to answer with a well-formed 413 rather than a bare drop.
  if ($length > _max_body()) {
    return {method => $method, path => $target, body => q{}, too_large => 1};
  }

  my $body = q{};
  while ($length > length $body) {
    if (!$select->can_read(_read_timeout())) {
      last;
    }
    my $chunk;
    my $read = sysread $connection, $chunk, $length - length $body;
    if (!$read) {
      last;
    }
    $body .= $chunk;
  }

  return {method => $method, path => $target, body => $body};
}

# Read a single CRLF-terminated line one byte at a time, bounding both the time
# we wait for data (so a slowloris client cannot pin the serial loop) and the
# length (so a client cannot exhaust memory with an unterminated line). Returns
# undef on timeout or a closed connection.
sub _read_limited_line {
  my ($connection, $select) = @_;
  my $line = q{};
  while (length $line < $MAX_LINE_BYTES) {
    if (!$select->can_read(_read_timeout())) {
      return;
    }
    my $char;
    my $read = sysread $connection, $char, 1;
    if (!$read) {
      return length $line ? $line : undef;
    }
    $line .= $char;
    if ($char eq "\n") {
      return $line;
    }
  }
  return $line;
}

sub _write_response {
  my ($connection, $response) = @_;
  my $status  = $response->{status} || 200;
  my $payload = $JSON->encode($response->{body} || {});
  my $length  = length $payload;

  print {$connection} "HTTP/1.1 $status ",
    _reason($status),
    "\r\nContent-Type: application/json\r\nContent-Length: $length\r\nConnection: close\r\n\r\n", $payload
    or die "print: $!\n";
  return 1;
}

my %REASON = (
  200 => 'OK',
  201 => 'Created',
  400 => 'Bad Request',
  404 => 'Not Found',
  409 => 'Conflict',
  413 => 'Payload Too Large',
  429 => 'Too Many Requests',
);

sub _reason {
  my ($status) = @_;
  return defined $REASON{$status} ? $REASON{$status} : 'Status';
}

1;

=head1 NAME

overnet-burner-adversary-server - HTTP binding for the adversary session API

=head1 VERSION

Version 0.001.

=head1 SYNOPSIS

  overnet-burner-adversary-server --host 127.0.0.1 --port 7480

=head1 DESCRIPTION

Serves L<Overnet::Burner::Adversary::Server> over HTTP so an external driver can
create adversary sessions, submit actions, read observations, and fetch
verdicts. The socket loop is intentionally thin - it decodes the request body as
JSON, calls C<< $server->dispatch >>, and encodes the response - so all API
behavior lives in the transport-neutral server module.

=head1 AUTHOR

Nicholas B. Hubbard C<< <nicholashubbard@posteo.net> >>

